# ═══════════════════════════════════════════════════════════════════════════
# Sociedad Rural — FRONTEND Environment Variables
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitear el archivo .env con valores reales.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Backend FastAPI ────────────────────────────────────────────────────────
# URL del backend en producción (VPS/Railway/Render)
VITE_API_URL="https://backend.agentech.ar"

# ─── Supabase ───────────────────────────────────────────────────────────────
# Usadas en AuthContext.tsx para refresh de tokens JWT
# La ANON KEY es pública por diseño pero no debe estar en el código fuente
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# ─── Firebase Web Push Notifications ───────────────────────────────────────
# Credenciales del proyecto Firebase Console → sociedad-rural-norte
# Estas claves son identificadores públicos (no son secretos del servidor)
# pero igualmente deben cargarse como env vars para facilitar rotaciones
# y mantener separación dev/staging/prod.
#
# Obtener en: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# VAPID Key para Web Push (FCM)
# Obtener en: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY="YOUR_VAPID_KEY"

# ─── NOTAS IMPORTANTES ──────────────────────────────────────────────────────
#
# Firebase (Push Notifications Android nativo):
#   Configurar via: android/app/google-services.json  (nativo Capacitor)
#   Estas variables VITE_ son solo para la PWA/WebView web.
#
# Firebase (Push Notifications iOS):
#   Configurar via: ios/App/App/GoogleService-Info.plist
#   ⚠️  iOS requiere Mac con Xcode — no compilable en Windows
#
# Bundle ID iOS/Android: com.agentech.sociedadrural
# versionName: 1.1.0 | versionCode: 3
#
# Variables que NO deben ir aquí (solo backend/.env):
#   SUPABASE_SERVICE_ROLE_KEY  → solo en BACKEND/.env
#   DATABASE_URL               → solo en BACKEND/.env
#   SECRET_KEY                 → solo en BACKEND/.env
#   EMAILS_EXCLUIDOS_MORA      → solo en BACKEND/.env
